{
  "root": true,
  "env": { "browser": true, "es2022": true },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "settings": { "react": { "version": "18" } },
  "rules": {
    "no-unused-vars": ["warn", { "varsIgnorePattern": "^React$" }]
  }
}
