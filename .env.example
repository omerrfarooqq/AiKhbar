# ============================================================
# AiKhbar — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Application ---
APP_NAME=AiKhbar
APP_ENV=development                 # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- PostgreSQL ---
POSTGRES_USER=aikhbar
POSTGRES_PASSWORD=aikhbar
POSTGRES_DB=aikhbar
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full async URL is derived from the above; override only if needed:
# DATABASE_URL=postgresql+asyncpg://aikhbar:aikhbar@localhost:5432/aikhbar

# --- Redis (optional caching) ---
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# --- NVIDIA NIM (LLM inference) ---
# Get a free key at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_LLM_MODEL_FAST=meta/llama-3.1-8b-instruct
NVIDIA_TEMPERATURE=0.3
NVIDIA_MAX_TOKENS=2048

# --- Embeddings (RAG) ---
# SentenceTransformers model used to build the FAISS index.
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DEVICE=cpu                # cpu | cuda
FAISS_INDEX_PATH=./storage/faiss/aikhbar.index
FAISS_META_PATH=./storage/faiss/aikhbar_meta.json

# --- TTS ---
# Primary TTS is Uplift AI's Orator (Pakistani-language speech); keys start sk_api_
TTS_PRIMARY=urdu_orator             # urdu_orator | coqui
URDU_ORATOR_API_KEY=
URDU_ORATOR_BASE_URL=https://api.upliftai.org/v1
URDU_ORATOR_VOICE_ID=v_30s70t3a     # v_30s70t3a Nostalgic News, v_8eelc901 Info
URDU_ORATOR_OUTPUT_FORMAT=MP3_22050_128
COQUI_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
AUDIO_CACHE_DIR=./storage/audio

# --- Scraping ---
SCRAPER_USER_AGENT=AiKhbarBot/1.0 (+https://github.com/omerrfarooqq/AiKhbar)
SCRAPE_INTERVAL_MINUTES=30
SCRAPE_REQUEST_TIMEOUT=20
SCRAPE_MAX_ARTICLES_PER_SOURCE=40

# --- Scheduler ---
SCHEDULER_ENABLED=true

# --- Logging ---
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false
